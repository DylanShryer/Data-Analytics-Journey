    Text
        LEFT()
            Syntax
                LEFT(text, [num_chars])
            Returns the first character(s) in a string based on the specified number of characters
            Example
                LEFT("Datacamp", 4) -> Data
        RIGHT()
            Syntax
                RIGHT(text, [num_chars])
            Returns the last character(s) in a string based on the specified number of characters
            Example
                RIGHT("Datacamp", 4) -> Camp
        UPPER()
            Syntax
                UPPER(text)
            Converts string to uppercase
            Example
                UPPER("Datacamp") -> DATACAMP
        LOWER()
            Syntax
                LOWER(text)
            Converts string to lowercase
            Example
                LOWER("Datacamp") -> datacamp
    Data and Time
        DATE()
            Syntax
                DATE(year, month, day)
            Returns a sequential serial number that represents a particular date
        DAY()
            Syntax
                DAY(<serial_number>)
            Returns the day of a corresponding date as an integer
        YEAR() 
            Syntax
                YEAR(<serial_number>)
            Returns the year to a corresponding data as an integer
    Math and Trig
        ROUND()
            Syntax
                ROUND(number, num_digits)
            Returns a number rounded to a specified number of digits
            Example
                ROUND(-1.475, 2) = -1.48
        ABS()
            Syntax
                ABS(number)
            Returns the absolute value of a number without its sign
            Example
                ABS(-2) = 2
        SUM()
    Statistical
        AVERAGE()
        COUNT()
        MIN()
        MAX()

